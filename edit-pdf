<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>PDF Editor · Annotate & Draw · iLovePDF Tools</title>
    <!-- PDF.js Core + Canvas render -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <!-- Fabric.js for drawing/editing overlay -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>
    <!-- JSZip for packaging -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <!-- pdf-lib for final PDF generation -->
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #eef2f7 0%, #dce5ed 100%);
            min-height: 100vh;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding: 20px;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            background: #ffffffea;
            border-radius: 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(98deg, #1e5f8e, #134b70);
            padding: 1.2rem 2rem;
            color: white;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }

        .header h1 {
            font-weight: 700;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .toolbar {
            background: #f8fafc;
            padding: 0.8rem 1.5rem;
            border-bottom: 1px solid #e2edf2;
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: center;
            justify-content: space-between;
        }

        .tools-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .tool-btn {
            background: white;
            border: 1px solid #cbd5e1;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .tool-btn.active {
            background: #1e5f8e;
            color: white;
            border-color: #1e5f8e;
        }

        .tool-btn:hover:not(:disabled) {
            background: #eef2ff;
            transform: translateY(-1px);
        }

        .color-picker {
            width: 40px;
            height: 36px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            cursor: pointer;
        }

        .editor-layout {
            display: flex;
            flex-direction: row;
            min-height: 70vh;
        }

        .pages-sidebar {
            width: 180px;
            background: #f9fbfd;
            border-right: 1px solid #e2edf2;
            padding: 1rem;
            overflow-y: auto;
            max-height: 65vh;
        }

        .page-thumb {
            background: white;
            border: 1px solid #dce5ec;
            border-radius: 8px;
            margin-bottom: 12px;
            padding: 6px;
            text-align: center;
            cursor: pointer;
            transition: 0.1s;
        }

        .page-thumb.active {
            border: 2px solid #1e5f8e;
            background: #f0f7ff;
        }

        .canvas-container {
            flex: 1;
            overflow: auto;
            background: #eef2f5;
            display: flex;
            justify-content: center;
            padding: 1rem;
            position: relative;
        }

        .pdf-canvas-wrapper {
            background: #fff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            display: inline-block;
            position: relative;
        }

        canvas {
            display: block;
        }

        .status-bar {
            padding: 0.7rem 1.5rem;
            background: #f1f5f9;
            border-top: 1px solid #e2edf2;
            font-size: 0.75rem;
            display: flex;
            justify-content: space-between;
        }

        button.primary-action {
            background: #1e5f8e;
            color: white;
            border: none;
            padding: 0.5rem 1.5rem;
            border-radius: 2rem;
            font-weight: 600;
        }

        input[type="file"] {
            display: none;
        }

        .drop-zone-sm {
            border: 1px dashed #90b4ce;
            border-radius: 2rem;
            padding: 0.2rem 1rem;
            background: #fff;
            font-size: 0.8rem;
            cursor: pointer;
        }

        @media (max-width: 780px) {
            .editor-layout { flex-direction: column; }
            .pages-sidebar { width: 100%; max-height: 120px; display: flex; gap: 0.5rem; overflow-x: auto; flex-direction: row; }
            .page-thumb { min-width: 70px; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="header">
        <h1>✏️ PDF Editor · Annotate & Draw</h1>
        <div class="tools-group">
            <div class="drop-zone-sm" id="loadPdfBtn">📂 Load PDF</div>
            <input type="file" id="pdfUpload" accept="application/pdf">
            <button id="savePdfBtn" class="primary-action">💾 Save Edited PDF</button>
        </div>
    </div>

    <div class="toolbar">
        <div class="tools-group">
            <button id="drawBtn" class="tool-btn">✏️ Draw</button>
            <button id="textBtn" class="tool-btn">📝 Add Text</button>
            <button id="selectBtn" class="tool-btn active">🖱️ Select/Move</button>
            <button id="clearBtn" class="tool-btn">🗑️ Clear All</button>
            <input type="color" id="colorPicker" value="#e34d4d" class="color-picker">
            <input type="range" id="strokeWidth" min="1" max="12" value="3" style="width:100px">
        </div>
        <div class="tools-group">
            <span style="font-size:0.7rem;">✍️ Draw / Add text / Move annotations</span>
        </div>
    </div>

    <div class="editor-layout">
        <div class="pages-sidebar" id="pagesSidebar"></div>
        <div class="canvas-container" id="canvasContainer">
            <div class="pdf-canvas-wrapper" id="canvasWrapper">
                <canvas id="pdfCanvas" width="600" height="800"></canvas>
            </div>
        </div>
    </div>
    <div class="status-bar">
        <span id="pageInfo">Page: 0 / 0</span>
        <span>✨ Annotations overlay — drawing, text boxes, move & resize</span>
    </div>
</div>

<script>
    // Configure PDF.js worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    
    // Global state
    let pdfDoc = null;
    let currentPageNum = 1;
    let totalPages = 0;
    let pdfRenderTask = null;
    let fabricCanvas = null;
    let currentMode = 'select'; // 'draw', 'text', 'select'
    let currentColor = '#e34d4d';
    let currentWidth = 3;
    let isDrawing = false;
    let originalPdfBuffer = null;
    let pageAnnotations = {}; // store fabric objects per page (JSON)
    let currentRenderedPage = 0;
    
    // DOM elements
    const pdfCanvas = document.getElementById('pdfCanvas');
    const canvasWrapper = document.getElementById('canvasWrapper');
    const pagesSidebar = document.getElementById('pagesSidebar');
    const loadPdfBtn = document.getElementById('loadPdfBtn');
    const pdfUpload = document.getElementById('pdfUpload');
    const savePdfBtn = document.getElementById('savePdfBtn');
    const drawBtn = document.getElementById('drawBtn');
    const textBtn = document.getElementById('textBtn');
    const selectBtn = document.getElementById('selectBtn');
    const clearBtn = document.getElementById('clearBtn');
    const colorPicker = document.getElementById('colorPicker');
    const strokeWidthInput = document.getElementById('strokeWidth');
    const pageInfoSpan = document.getElementById('pageInfo');
    
    // Init Fabric overlay
    function initFabricCanvas(width, height) {
        if (fabricCanvas) {
            fabricCanvas.dispose();
        }
        fabricCanvas = new fabric.Canvas('pdfCanvas', {
            selection: true,
            preserveObjectStacking: true,
            width: width,
            height: height,
            backgroundColor: 'transparent'
        });
        fabricCanvas.setWidth(width);
        fabricCanvas.setHeight(height);
        fabricCanvas.renderAll();
        
        // set drawing mode
        fabricCanvas.isDrawingMode = (currentMode === 'draw');
        fabricCanvas.freeDrawingBrush.color = currentColor;
        fabricCanvas.freeDrawingBrush.width = currentWidth;
        fabricCanvas.selection = (currentMode === 'select');
        
        // event handlers for drawing mode
        fabricCanvas.on('path:created', () => { saveCurrentPageAnnotations(); });
        fabricCanvas.on('object:modified', () => { saveCurrentPageAnnotations(); });
        fabricCanvas.on('object:added', () => { saveCurrentPageAnnotations(); });
        fabricCanvas.on('object:removed', () => { saveCurrentPageAnnotations(); });
        
        // text mode: double-click to add text
        fabricCanvas.off('mouse:dblclick');
        fabricCanvas.on('mouse:dblclick', (e) => {
            if (currentMode === 'text') {
                const pointer = fabricCanvas.getPointer(e.e);
                addTextAt(pointer.x, pointer.y);
            }
        });
    }
    
    function addTextAt(x, y) {
        const textbox = new fabric.Textbox('Edit text', {
            left: x,
            top: y,
            fontSize: 20,
            fill: currentColor,
            fontFamily: 'Arial',
            width: 150,
            editable: true,
            borderColor: '#1e5f8e',
            cornerColor: '#1e5f8e'
        });
        fabricCanvas.add(textbox);
        fabricCanvas.setActiveObject(textbox);
        fabricCanvas.renderAll();
        saveCurrentPageAnnotations();
    }
    
    function saveCurrentPageAnnotations() {
        if (!fabricCanvas || !currentPageNum) return;
        const objects = fabricCanvas.toJSON();
        pageAnnotations[currentPageNum] = objects;
    }
    
    function loadAnnotationsForPage(pageNum) {
        if (!fabricCanvas) return;
        fabricCanvas.clear();
        fabricCanvas.backgroundColor = 'transparent';
        if (pageAnnotations[pageNum] && pageAnnotations[pageNum].objects) {
            fabricCanvas.loadFromJSON(pageAnnotations[pageNum], () => {
                fabricCanvas.renderAll();
                // reapply drawing mode settings
                fabricCanvas.isDrawingMode = (currentMode === 'draw');
                fabricCanvas.freeDrawingBrush.color = currentColor;
                fabricCanvas.freeDrawingBrush.width = currentWidth;
                fabricCanvas.selection = (currentMode === 'select');
            });
        } else {
            fabricCanvas.renderAll();
        }
    }
    
    // Render PDF page to background canvas (fabric background)
    async function renderPage(pageNum) {
        if (!pdfDoc) return;
        if (pdfRenderTask) pdfRenderTask.cancel();
        const page = await pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: 1.8 }); // good resolution
        const scale = 1.8;
        const width = viewport.width;
        const height = viewport.height;
        
        // resize fabric canvas and main canvas element
        pdfCanvas.width = width;
        pdfCanvas.height = height;
        pdfCanvas.style.width = `${width}px`;
        pdfCanvas.style.height = `${height}px`;
        canvasWrapper.style.width = `${width}px`;
        canvasWrapper.style.height = `${height}px`;
        
        const context = pdfCanvas.getContext('2d');
        const renderContext = {
            canvasContext: context,
            viewport: viewport,
            background: 'white'
        };
        await page.render(renderContext).promise;
        
        // (Re)init fabric overlay with same dimensions
        initFabricCanvas(width, height);
        loadAnnotationsForPage(pageNum);
        currentRenderedPage = pageNum;
        pageInfoSpan.innerText = `Page ${pageNum} / ${totalPages}`;
        updateThumbnailsActive();
    }
    
    async function loadPDF(arrayBuffer, filename) {
        originalPdfBuffer = arrayBuffer;
        pdfDoc = await pdfjsLib.getDocument({ data: arrayBuffer.slice() }).promise;
        totalPages = pdfDoc.numPages;
        pageAnnotations = {};
        currentPageNum = 1;
        renderPage(1);
        buildThumbnails();
    }
    
    async function buildThumbnails() {
        if (!pdfDoc) return;
        pagesSidebar.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
            const thumbDiv = document.createElement('div');
            thumbDiv.className = 'page-thumb';
            thumbDiv.innerText = `Page ${i}`;
            thumbDiv.addEventListener('click', () => {
                if (currentPageNum !== i) {
                    currentPageNum = i;
                    renderPage(currentPageNum);
                }
            });
            pagesSidebar.appendChild(thumbDiv);
        }
        updateThumbnailsActive();
    }
    
    function updateThumbnailsActive() {
        const thumbs = document.querySelectorAll('.page-thumb');
        thumbs.forEach((el, idx) => {
            if (idx + 1 === currentPageNum) el.classList.add('active');
            else el.classList.remove('active');
        });
    }
    
    // Save final PDF with annotations merged using pdf-lib (embed each page as image + overlay)
    async function exportEditedPDF() {
        if (!pdfDoc || !originalPdfBuffer) {
            alert("No PDF loaded");
            return;
        }
        saveCurrentPageAnnotations(); // ensure latest annotations saved
        const { PDFDocument } = PDFLib;
        const pdfBytesOriginal = originalPdfBuffer;
        const newPdfDoc = await PDFDocument.load(pdfBytesOriginal);
        const total = totalPages;
        
        for (let pageNum = 1; pageNum <= total; pageNum++) {
            // render pdf page to canvas at high quality
            const page = await pdfDoc.getPage(pageNum);
            const viewport = page.getViewport({ scale: 2.2 });
            const canvas = document.createElement('canvas');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            const ctx = canvas.getContext('2d');
            await page.render({ canvasContext: ctx, viewport: viewport, background: 'white' }).promise;
            
            // if we have fabric annotations for this page, we need to merge them
            if (pageAnnotations[pageNum] && pageAnnotations[pageNum].objects && pageAnnotations[pageNum].objects.length > 0) {
                // create separate fabric canvas to draw annotations on top
                const fabricOverlay = new fabric.Canvas(null, { width: viewport.width, height: viewport.height });
                fabricOverlay.loadFromJSON(pageAnnotations[pageNum], () => {
                    fabricOverlay.renderAll();
                });
                await new Promise(resolve => setTimeout(resolve, 50));
                const overlayCanvas = fabricOverlay.getElement();
                ctx.drawImage(overlayCanvas, 0, 0);
                fabricOverlay.dispose();
            }
            
            const imgData = canvas.toDataURL('image/jpeg', 0.92);
            const jpgImage = await newPdfDoc.embedJpg(imgData.split(',')[1], { base64: true });
            const pdfPage = newPdfDoc.getPages()[pageNum - 1];
            const { width, height } = pdfPage.getSize();
            pdfPage.drawImage(jpgImage, { x: 0, y: 0, width: width, height: height });
        }
        const finalPdfBytes = await newPdfDoc.save();
        const blob = new Blob([finalPdfBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'edited_document.pdf';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        alert("PDF saved with annotations!");
    }
    
    // UI Event Binding
    loadPdfBtn.addEventListener('click', () => pdfUpload.click());
    pdfUpload.addEventListener('change', async (e) => {
        if (e.target.files.length) {
            const file = e.target.files[0];
            if (file.type !== 'application/pdf') {
                alert("Please upload a valid PDF.");
                return;
            }
            const buffer = await file.arrayBuffer();
            await loadPDF(buffer, file.name);
        }
        pdfUpload.value = '';
    });
    
    savePdfBtn.addEventListener('click', exportEditedPDF);
    
    drawBtn.addEventListener('click', () => {
        currentMode = 'draw';
        if (fabricCanvas) {
            fabricCanvas.isDrawingMode = true;
            fabricCanvas.selection = false;
            fabricCanvas.forEachObject(obj => obj.selectable = false);
        }
        drawBtn.classList.add('active');
        textBtn.classList.remove('active');
        selectBtn.classList.remove('active');
    });
    
    textBtn.addEventListener('click', () => {
        currentMode = 'text';
        if (fabricCanvas) {
            fabricCanvas.isDrawingMode = false;
            fabricCanvas.selection = false;
            fabricCanvas.forEachObject(obj => obj.selectable = true);
        }
        textBtn.classList.add('active');
        drawBtn.classList.remove('active');
        selectBtn.classList.remove('active');
    });
    
    selectBtn.addEventListener('click', () => {
        currentMode = 'select';
        if (fabricCanvas) {
            fabricCanvas.isDrawingMode = false;
            fabricCanvas.selection = true;
            fabricCanvas.forEachObject(obj => obj.selectable = true);
        }
        selectBtn.classList.add('active');
        drawBtn.classList.remove('active');
        textBtn.classList.remove('active');
    });
    
    clearBtn.addEventListener('click', () => {
        if (fabricCanvas && confirm('Delete all annotations on this page?')) {
            fabricCanvas.clear();
            fabricCanvas.backgroundColor = 'transparent';
            saveCurrentPageAnnotations();
            fabricCanvas.renderAll();
        }
    });
    
    colorPicker.addEventListener('change', (e) => {
        currentColor = e.target.value;
        if (fabricCanvas) {
            fabricCanvas.freeDrawingBrush.color = currentColor;
        }
    });
    
    strokeWidthInput.addEventListener('change', (e) => {
        currentWidth = parseInt(e.target.value, 10);
        if (fabricCanvas) {
            fabricCanvas.freeDrawingBrush.width = currentWidth;
        }
    });
    
    // Helper to reapply brush settings on mode switch
    function syncBrush() {
        if (fabricCanvas) {
            fabricCanvas.freeDrawingBrush.color = currentColor;
            fabricCanvas.freeDrawingBrush.width = currentWidth;
        }
    }
    setInterval(syncBrush, 200);
    
    // initial placeholder
    initFabricCanvas(600, 800);
    fabricCanvas.isDrawingMode = false;
    fabricCanvas.selection = true;
    currentMode = 'select';
    selectBtn.classList.add('active');
    statusMessage('Ready — Load PDF to start editing');
    
    function statusMessage(msg) {
        const statusSpan = document.querySelector('.status-bar span:first-child');
        if (statusSpan) statusSpan.innerText = msg;
    }
</script>
</body>
</html>
