<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>PDF Splitter • Extract & Split PDF Pages (Client-Side)</title>
  <!-- PDF-Lib for robust PDF splitting -->
  <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #f0f4f8 0%, #e6edf4 100%);
      font-family: 'Segoe UI', Roboto, 'Inter', system-ui, sans-serif;
      padding: 2rem 1.2rem;
      color: #1a2e3f;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* header */
    .header-section {
      text-align: center;
      margin-bottom: 2rem;
    }
    .header-section h1 {
      font-size: 2.6rem;
      font-weight: 800;
      background: linear-gradient(145deg, #1e5575, #2c6e8f);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.3px;
    }
    .header-section p {
      color: #406e88;
      max-width: 700px;
      margin: 0.5rem auto 0;
    }

    /* main card */
    .split-card {
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(0px);
      border-radius: 2rem;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12);
      padding: 2rem;
      margin-bottom: 2rem;
      border: 1px solid #eef3fc;
      transition: all 0.2s;
    }

    /* upload area */
    .upload-zone {
      border: 2px dashed #bdd9ec;
      border-radius: 1.5rem;
      background: #ffffff;
      padding: 2.2rem 1rem;
      text-align: center;
      cursor: pointer;
      transition: 0.2s ease;
      margin-bottom: 1.5rem;
    }
    .upload-zone:hover {
      border-color: #2c6e8f;
      background: #fbfefe;
      transform: scale(0.99);
    }
    .upload-icon {
      font-size: 3.2rem;
      color: #2c6e8f;
      margin-bottom: 0.8rem;
    }
    .file-input-hidden {
      display: none;
    }
    .btn {
      background: #2c6e8f;
      border: none;
      color: white;
      padding: 0.7rem 1.5rem;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }
    .btn-outline {
      background: transparent;
      border: 1px solid #c2d9ec;
      color: #2a607f;
      box-shadow: none;
    }
    .btn-outline:hover {
      background: #eef6fd;
      border-color: #2c6e8f;
    }
    .btn-danger-light {
      background: #fff6f0;
      color: #c27d5c;
      border: 1px solid #f3dfd0;
    }
    .btn-danger-light:hover {
      background: #ffe8de;
      color: #b34e2c;
    }
    .btn:hover {
      background: #1e5775;
      transform: translateY(-1px);
    }

    /* file info */
    .pdf-info {
      background: #f2f8fe;
      border-radius: 1.2rem;
      padding: 1rem 1.5rem;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .pdf-name {
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* split controls - range / intervals */
    .split-options {
      margin: 1.8rem 0 1.2rem;
    }
    .option-tabs {
      display: flex;
      gap: 12px;
      border-bottom: 1px solid #e1eef9;
      margin-bottom: 1.4rem;
    }
    .tab-btn {
      background: none;
      border: none;
      padding: 0.5rem 1.2rem;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      color: #547b96;
      transition: 0.2s;
      border-radius: 30px;
    }
    .tab-btn.active {
      background: #e3f0f7;
      color: #1e5d7c;
      box-shadow: inset 0 0 0 1px #c9e2f0;
    }
    .tab-pane {
      display: none;
      animation: fade 0.2s ease;
    }
    .tab-pane.active-pane {
      display: block;
    }
    @keyframes fade {
      from { opacity: 0; transform: translateY(5px);}
      to { opacity: 1; transform: translateY(0);}
    }

    .input-group {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      align-items: flex-end;
      margin-bottom: 1rem;
    }
    .input-field {
      flex: 1;
      min-width: 150px;
    }
    .input-field label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #607f97;
      margin-bottom: 5px;
    }
    .input-field input, .input-field select {
      width: 100%;
      padding: 0.6rem 0.9rem;
      border-radius: 60px;
      border: 1px solid #cfe1ee;
      background: white;
      font-size: 0.9rem;
    }
    .range-hint {
      font-size: 0.7rem;
      color: #6c8ea8;
      margin-top: 4px;
    }

    /* preview pages & split result list */
    .preview-area {
      margin: 1.5rem 0;
    }
    .pages-note {
      background: #eef3f5;
      border-radius: 1rem;
      padding: 0.7rem 1rem;
      font-size: 0.85rem;
    }
    .split-jobs-list {
      background: #fafcfd;
      border-radius: 1.2rem;
      padding: 0.8rem;
      max-height: 280px;
      overflow-y: auto;
      border: 1px solid #e5f0f7;
    }
    .job-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7rem 1rem;
      border-bottom: 1px solid #e9f0f5;
      gap: 12px;
    }
    .job-details {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      font-size: 0.85rem;
    }
    .badge-pages {
      background: #e0edf5;
      border-radius: 30px;
      padding: 0.2rem 0.8rem;
      font-weight: 500;
      font-family: monospace;
    }
    .remove-job {
      background: none;
      border: none;
      font-size: 1.1rem;
      color: #b8cfdf;
      cursor: pointer;
    }
    .remove-job:hover { color: #cd6b4b; }

    .action-bar {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin: 1.8rem 0 1rem;
      flex-wrap: wrap;
    }

    .status-area {
      margin-top: 1.2rem;
      background: #eef3f9;
      border-radius: 1.2rem;
      padding: 1rem;
      text-align: center;
      font-size: 0.9rem;
      transition: 0.1s;
    }
    .success-status {
      background: #e0f2e9;
      color: #1b6e4b;
    }
    .error-status {
      background: #ffe9e5;
      color: #bc5a42;
    }
    footer {
      text-align: center;
      font-size: 0.75rem;
      color: #698ba3;
      margin-top: 1rem;
    }
    @media (max-width: 660px) {
      .split-card { padding: 1.2rem; }
      .job-details { flex-direction: column; gap: 4px; }
    }
  </style>
</head>
<body>
<div class="container">
  <div class="header-section">
    <h1><i class="fas fa-cut"></i> PDF Splitter</h1>
    <p>Extract specific page ranges, split by intervals, or separate every N pages — all inside your browser, private and secure.</p>
  </div>

  <div class="split-card">
    <!-- PDF upload zone -->
    <div class="upload-zone" id="uploadZone">
      <div class="upload-icon"><i class="fas fa-file-pdf"></i></div>
      <p><strong>Click or drop a PDF file</strong> <br><span style="font-size: 0.8rem;">(max ~100 MB, client-side processing)</span></p>
      <input type="file" id="pdfUpload" accept=".pdf" class="file-input-hidden">
    </div>

    <!-- PDF loaded info + total pages -->
    <div id="pdfLoadedSection" style="display: none;">
      <div class="pdf-info">
        <div class="pdf-name"><i class="fas fa-check-circle" style="color:#2c8f6e;"></i> <span id="pdfFileName"></span></div>
        <div><span id="totalPagesSpan" class="badge-pages"></span> pages total</div>
        <button id="clearPdfBtn" class="btn-outline btn" style="padding: 0.3rem 1rem;"><i class="fas fa-sync-alt"></i> Change PDF</button>
      </div>

      <!-- split method selection -->
      <div class="split-options">
        <div class="option-tabs">
          <button class="tab-btn active" data-method="range">📄 Custom ranges</button>
          <button class="tab-btn" data-method="intervals">✂️ Split by intervals</button>
          <button class="tab-btn" data-method="every">📑 Every N pages</button>
        </div>

        <!-- PANE: custom page ranges -->
        <div id="rangePane" class="tab-pane active-pane">
          <div class="input-group">
            <div class="input-field">
              <label>Page ranges (e.g., 1-3,5,7-9)</label>
              <input type="text" id="rangeInput" placeholder="1-5, 8, 11-13" value="1-3">
              <div class="range-hint">Use commas to separate ranges. Example: 1-3,5,7-10</div>
            </div>
            <div class="input-field">
              <label>Extract as single PDF</label>
              <button id="addRangeSplitBtn" class="btn" style="margin-top: 1.4rem;"><i class="fas fa-plus"></i> Add this range</button>
            </div>
          </div>
        </div>

        <!-- PANE: intervals (split into equal groups of pages) -->
        <div id="intervalPane" class="tab-pane">
          <div class="input-group">
            <div class="input-field">
              <label>Pages per split document</label>
              <input type="number" id="pagesPerSplit" min="1" max="500" value="2">
              <div class="range-hint">Each output PDF will contain up to X pages (consecutive).</div>
            </div>
            <div class="input-field">
              <label>&nbsp;</label>
              <button id="addIntervalSplitBtn" class="btn" style="margin-top: 0.2rem;"><i class="fas fa-layer-group"></i> Generate intervals</button>
            </div>
          </div>
        </div>

        <!-- PANE: every N pages (extract 1 page out of every N) -->
        <div id="everyPane" class="tab-pane">
          <div class="input-group">
            <div class="input-field">
              <label>Every N pages (step)</label>
              <input type="number" id="stepValue" min="1" max="50" value="2">
              <div class="range-hint">e.g. step=2 → pages 2,4,6... | step=1 → all pages</div>
            </div>
            <div class="input-field">
              <label>Starting page (optional)</label>
              <input type="number" id="startPage" min="1" value="1">
            </div>
            <div class="input-field">
              <label>&nbsp;</label>
              <button id="addStepSplitBtn" class="btn" style="margin-top: 0.2rem;"><i class="fas fa-code-branch"></i> Add step split</button>
            </div>
          </div>
        </div>
      </div>

      <!-- split jobs queue (what will be extracted) -->
      <div style="margin-top: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap;">
          <h3 style="font-size: 1rem;"><i class="fas fa-list-ul"></i> Split jobs (<span id="jobCount">0</span>)</h3>
          <button id="clearJobsBtn" class="btn-outline btn" style="padding: 0.2rem 1rem;"><i class="fas fa-trash-alt"></i> Clear all jobs</button>
        </div>
        <div id="jobsListContainer" class="split-jobs-list" style="margin-top: 10px;">
          <div style="text-align: center; color: #7b9bb3; padding: 1rem;">Add a split operation to extract PDF parts.</div>
        </div>
      </div>

      <div class="action-bar">
        <button id="performSplitBtn" class="btn"><i class="fas fa-code-branch"></i> Split & Download as ZIP</button>
        <button id="downloadAllAsSingleBtn" class="btn-outline btn"><i class="fas fa-compress-alt"></i> Merge all into single PDF</button>
      </div>
      <div id="splitStatus" class="status-area">
        <i class="fas fa-info-circle"></i> Upload a PDF, then add split rules.
      </div>
    </div>
  </div>
  <footer>
    <i class="fas fa-shield-alt"></i> 100% local processing. No file upload. Uses pdf-lib and JSZip (auto-generated ZIP). 
    <span id="jszipStatus"></span>
  </footer>
</div>

<!-- Load JSZip dynamically from CDN for zip generation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
  // ---------- Global state ----------
  let currentPdfBytes = null;         // Uint8Array of source PDF
  let currentPdfDoc = null;           // pdf-lib document instance
  let totalPages = 0;
  let currentFileName = "document";
  let splitJobs = [];                 // each job: { description, getPageIndices: () => number[] }

  // DOM elements
  const uploadZone = document.getElementById('uploadZone');
  const fileInput = document.getElementById('pdfUpload');
  const pdfLoadedSection = document.getElementById('pdfLoadedSection');
  const pdfFileNameSpan = document.getElementById('pdfFileName');
  const totalPagesSpan = document.getElementById('totalPagesSpan');
  const clearPdfBtn = document.getElementById('clearPdfBtn');
  const rangeInput = document.getElementById('rangeInput');
  const addRangeBtn = document.getElementById('addRangeSplitBtn');
  const pagesPerSplitInput = document.getElementById('pagesPerSplit');
  const addIntervalBtn = document.getElementById('addIntervalSplitBtn');
  const stepValueInput = document.getElementById('stepValue');
  const startPageInput = document.getElementById('startPage');
  const addStepBtn = document.getElementById('addStepSplitBtn');
  const jobsListContainer = document.getElementById('jobsListContainer');
  const jobCountSpan = document.getElementById('jobCount');
  const clearJobsBtn = document.getElementById('clearJobsBtn');
  const performSplitBtn = document.getElementById('performSplitBtn');
  const splitStatus = document.getElementById('splitStatus');
  const downloadAllAsSingleBtn = document.getElementById('downloadAllAsSingleBtn');

  // TABS
  const tabBtns = document.querySelectorAll('.tab-btn');
  const panes = {
    range: document.getElementById('rangePane'),
    intervals: document.getElementById('intervalPane'),
    every: document.getElementById('everyPane')
  };

  // Helper: update job UI
  function renderJobs() {
    if (!jobsListContainer) return;
    if (splitJobs.length === 0) {
      jobsListContainer.innerHTML = `<div style="text-align: center; color: #7b9bb3; padding: 1rem;">No split jobs added. Use the tools above to define how to split the PDF.</div>`;
      jobCountSpan.innerText = '0';
      return;
    }
    let html = '';
    splitJobs.forEach((job, idx) => {
      html += `
        <div class="job-item">
          <div class="job-details">
            <span class="badge-pages">#${idx+1}</span>
            <span><i class="far fa-file-pdf"></i> ${escapeHtml(job.description)}</span>
          </div>
          <button class="remove-job" data-jobidx="${idx}"><i class="fas fa-trash-alt"></i></button>
        </div>
      `;
    });
    jobsListContainer.innerHTML = html;
    jobCountSpan.innerText = splitJobs.length;
    document.querySelectorAll('.remove-job').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt(btn.getAttribute('data-jobidx'));
        splitJobs.splice(idx, 1);
        renderJobs();
        updateStatusMessage('Job removed.', false);
      });
    });
  }

  function escapeHtml(str) { return str.replace(/[&<>]/g, function(m){if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;}); }
  function updateStatusMessage(msg, isError=false) {
    splitStatus.innerHTML = isError ? `<i class="fas fa-exclamation-triangle"></i> ${msg}` : `<i class="fas fa-info-circle"></i> ${msg}`;
    if (isError) splitStatus.classList.add('error-status'); else splitStatus.classList.remove('error-status');
    setTimeout(() => { if(!isError) splitStatus.classList.remove('error-status'); }, 3000);
  }

  // Parse page range string -> array of page numbers (1-indexed)
  function parseRangeString(rangeStr, totalPages) {
    const pagesSet = new Set();
    const parts = rangeStr.split(',');
    for (let part of parts) {
      part = part.trim();
      if (part.includes('-')) {
        let [start, end] = part.split('-').map(v => parseInt(v.trim(), 10));
        if (isNaN(start)) continue;
        if (isNaN(end)) end = start;
        start = Math.max(1, start);
        end = Math.min(totalPages, end);
        for (let i = start; i <= end; i++) pagesSet.add(i);
      } else {
        let p = parseInt(part, 10);
        if (!isNaN(p) && p >= 1 && p <= totalPages) pagesSet.add(p);
      }
    }
    return Array.from(pagesSet).sort((a,b)=>a-b);
  }

  // Add job: custom range
  function addRangeJob() {
    if (!currentPdfDoc) { updateStatusMessage('No PDF loaded', true); return; }
    const rangeText = rangeInput.value.trim();
    if (!rangeText) { updateStatusMessage('Enter page ranges', true); return; }
    const pages = parseRangeString(rangeText, totalPages);
    if (pages.length === 0) { updateStatusMessage('Invalid range (out of bounds or empty)', true); return; }
    const desc = `Pages: ${rangeText} → ${pages.length} page(s)`;
    splitJobs.push({
      description: desc,
      getPageIndices: () => pages.map(p => p-1) // zero-indexed for pdf-lib
    });
    renderJobs();
    updateStatusMessage(`Added: ${desc}`, false);
  }

  // split by intervals (fixed pages per split)
  function addIntervalsJob() {
    if (!currentPdfDoc) return updateStatusMessage('Load PDF first', true);
    let perSplit = parseInt(pagesPerSplitInput.value, 10);
    if (isNaN(perSplit) || perSplit < 1) perSplit = 1;
    const jobsAdded = [];
    for (let start = 1; start <= totalPages; start += perSplit) {
      let end = Math.min(start + perSplit - 1, totalPages);
      let pageRange = [];
      for (let i = start; i <= end; i++) pageRange.push(i-1);
      if (pageRange.length) {
        const desc = `Interval [${start}-${end}] (${pageRange.length} pages)`;
        splitJobs.push({ description: desc, getPageIndices: () => pageRange });
        jobsAdded.push(desc);
      }
    }
    renderJobs();
    updateStatusMessage(`Added ${jobsAdded.length} interval segments.`, false);
  }

  // step split: every N pages (starting from startPage)
  function addStepSplitJob() {
    if (!currentPdfDoc) return updateStatusMessage('Load PDF first', true);
    let step = parseInt(stepValueInput.value, 10);
    let start = parseInt(startPageInput.value, 10);
    if (isNaN(step) || step < 1) step = 1;
    if (isNaN(start) || start < 1) start = 1;
    const selectedPages = [];
    for (let p = start; p <= totalPages; p += step) {
      selectedPages.push(p-1);
    }
    if (selectedPages.length === 0) { updateStatusMessage('No pages selected', true); return; }
    const desc = `Every ${step} page(s) from page ${start} → ${selectedPages.length} pages.`;
    splitJobs.push({
      description: desc,
      getPageIndices: () => selectedPages
    });
    renderJobs();
    updateStatusMessage(`Added: ${desc}`, false);
  }

  async function loadPdf(file) {
    if (!file || file.type !== 'application/pdf') { updateStatusMessage('Invalid PDF file', true); return false; }
    try {
      const arrayBuffer = await file.arrayBuffer();
      const uint8Array = new Uint8Array(arrayBuffer);
      const pdfDoc = await PDFLib.PDFDocument.load(uint8Array);
      currentPdfDoc = pdfDoc;
      currentPdfBytes = uint8Array;
      totalPages = pdfDoc.getPageCount();
      currentFileName = file.name.replace(/\.pdf$/i, '');
      pdfFileNameSpan.innerText = file.name;
      totalPagesSpan.innerText = totalPages;
      pdfLoadedSection.style.display = 'block';
      splitJobs = []; renderJobs();
      updateStatusMessage(`Loaded "${file.name}" — ${totalPages} pages. Create split jobs.`, false);
      return true;
    } catch(e) { updateStatusMessage(`Error loading PDF: ${e.message}`, true); return false; }
  }

  // reset UI
  function clearPdfAndReset() {
    currentPdfDoc = null;
    currentPdfBytes = null;
    totalPages = 0;
    pdfLoadedSection.style.display = 'none';
    splitJobs = [];
    renderJobs();
    fileInput.value = '';
    updateStatusMessage('PDF cleared. Upload a new file.', false);
  }

  // perform split & download ZIP or single merged
  async function performSplit(asSinglePdf = false) {
    if (!currentPdfDoc) { updateStatusMessage('No PDF loaded', true); return; }
    if (splitJobs.length === 0) { updateStatusMessage('Add at least one split job first', true); return; }

    performSplitBtn.disabled = true;
    downloadAllAsSingleBtn.disabled = true;
    splitStatus.innerHTML = `<i class="fas fa-spinner fa-pulse"></i> Processing ${splitJobs.length} split part(s)...`;
    try {
      const sourceDoc = currentPdfDoc;
      if (asSinglePdf) {
        // Merge all jobs into one PDF (each job's selected pages appended)
        const mergedPdf = await PDFLib.PDFDocument.create();
        for (let job of splitJobs) {
          const pageIndices = job.getPageIndices();
          if (pageIndices.length === 0) continue;
          const pagesToCopy = await mergedPdf.copyPages(sourceDoc, pageIndices);
          pagesToCopy.forEach(p => mergedPdf.addPage(p));
        }
        const mergedBytes = await mergedPdf.save();
        const blob = new Blob([mergedBytes], {type: 'application/pdf'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${currentFileName}_merged_split.pdf`;
        a.click();
        URL.revokeObjectURL(url);
        splitStatus.innerHTML = `<i class="fas fa-check-circle"></i> Single merged PDF created! (${mergedPdf.getPageCount()} pages)`;
      } else {
        // Generate a ZIP containing each split as separate PDF
        const zip = new JSZip();
        let successCount = 0;
        for (let idx = 0; idx < splitJobs.length; idx++) {
          const job = splitJobs[idx];
          const pageIndices = job.getPageIndices();
          if (pageIndices.length === 0) continue;
          const newPdf = await PDFLib.PDFDocument.create();
          const copied = await newPdf.copyPages(sourceDoc, pageIndices);
          copied.forEach(p => newPdf.addPage(p));
          const pdfBytes = await newPdf.save();
          const safeName = `${currentFileName}_part${(idx+1).toString().padStart(2,'0')}.pdf`;
          zip.file(safeName, pdfBytes);
          successCount++;
        }
        const zipBlob = await zip.generateAsync({ type: "blob" });
        const url = URL.createObjectURL(zipBlob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${currentFileName}_split_parts.zip`;
        a.click();
        URL.revokeObjectURL(url);
        splitStatus.innerHTML = `<i class="fas fa-check-circle"></i> ZIP ready! ${successCount} PDFs downloaded.`;
      }
    } catch(err) {
      splitStatus.innerHTML = `<i class="fas fa-exclamation-triangle"></i> Error: ${err.message}`;
      splitStatus.classList.add('error-status');
    } finally {
      performSplitBtn.disabled = false;
      downloadAllAsSingleBtn.disabled = false;
      setTimeout(() => splitStatus.classList.remove('error-status'), 3000);
    }
  }

  // event listeners
  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.style.backgroundColor='#f0f8ff'; });
  uploadZone.addEventListener('dragleave', () => { uploadZone.style.backgroundColor='#ffffff'; });
  uploadZone.addEventListener('drop', async (e) => {
    e.preventDefault(); uploadZone.style.backgroundColor='#ffffff';
    const files = e.dataTransfer.files;
    if (files.length && files[0].type === 'application/pdf') await loadPdf(files[0]);
    else updateStatusMessage('Drop a valid PDF file', true);
  });
  fileInput.addEventListener('change', async (e) => { if(e.target.files.length) await loadPdf(e.target.files[0]); });
  clearPdfBtn.addEventListener('click', clearPdfAndReset);
  addRangeBtn.addEventListener('click', addRangeJob);
  addIntervalBtn.addEventListener('click', addIntervalsJob);
  addStepBtn.addEventListener('click', addStepSplitJob);
  clearJobsBtn.addEventListener('click', () => { splitJobs = []; renderJobs(); updateStatusMessage('All split jobs cleared.', false); });
  performSplitBtn.addEventListener('click', () => performSplit(false));
  downloadAllAsSingleBtn.addEventListener('click', () => performSplit(true));
  
  // TABS switching
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const method = btn.getAttribute('data-method');
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      Object.keys(panes).forEach(key => panes[key].classList.remove('active-pane'));
      if (method === 'range') panes.range.classList.add('active-pane');
      else if (method === 'intervals') panes.intervals.classList.add('active-pane');
      else if (method === 'every') panes.every.classList.add('active-pane');
    });
  });
</script>
</body>
</html>
